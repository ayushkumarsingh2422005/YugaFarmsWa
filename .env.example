# =============================================================================
# Yuga Farms WhatsApp service (yuga-farms-wa) — copy to .env.local on VPS
# Runs beside YugaFarms storefront + YugaFarmsBackend (Strapi) on the same host.
# =============================================================================

# App
NODE_ENV=production
PORT=3001
NEXT_PUBLIC_APP_URL=https://wa.yugafarms.com

# Shared secret: must match YugaFarms NEXT_PUBLIC_* / server calls (x-wa-internal-secret header)
WA_INTERNAL_SECRET=generate_a_long_random_string_here

# Cron / scheduled message processor (call GET /api/cron/process-messages with this header)
CRON_SECRET=another_long_random_string_for_cron_only

# -----------------------------------------------------------------------------
# Meta WhatsApp Cloud API (Business Platform → WhatsApp → API Setup)
# -----------------------------------------------------------------------------
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=

# Webhook verify token (you choose this; same value in Meta App → WhatsApp → Configuration)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# App secret from Meta Developer App (validates X-Hub-Signature-256 on incoming webhooks)
WHATSAPP_APP_SECRET=

# Optional: default country code when normalizing 10-digit Indian numbers
WHATSAPP_DEFAULT_COUNTRY_CODE=91

# -----------------------------------------------------------------------------
# Strapi SQLite (read-only) — same VPS path as YugaFarmsBackend
# -----------------------------------------------------------------------------
STRAPI_DATABASE_PATH=../YugaFarmsBackend/.tmp/data.db

# Optional Strapi REST fallback if DB path unavailable (API token with read access)
STRAPI_API_URL=https://server.yugafarms.com
STRAPI_API_TOKEN=

# -----------------------------------------------------------------------------
# This service's SQLite (scheduled messages, cart snapshots, chat log)
# -----------------------------------------------------------------------------
WA_DATABASE_PATH=./data/wa.db

# -----------------------------------------------------------------------------
# Message timing (days)
# -----------------------------------------------------------------------------
# After order marked DELIVERED in Strapi
WA_REVIEW_DAYS_AFTER_DELIVERY=4
WA_PRODUCT_INSIGHTS_DAYS_AFTER_DELIVERY=10

# JSON map: variant weight (grams/ml) → days until repurchase reminder
# Client example: 500ml → 12 days, 1L (1000) → 25 days
PRODUCT_CONSUMPTION_CYCLES={"250":7,"500":12,"1000":25,"2000":45}

# -----------------------------------------------------------------------------
# Cart ↔ WhatsApp chatbot (optional)
# If your chatbot vendor exposes an HTTP endpoint to push cart JSON into a session:
# -----------------------------------------------------------------------------
WHATSAPP_CART_WEBHOOK_URL=
WHATSAPP_CART_WEBHOOK_SECRET=

# Set true to send a WhatsApp text on each cart sync (usually keep false; use chatbot webhook instead)
WA_SEND_CART_MESSAGES=false

# Site URLs used in message copy
STOREFRONT_URL=https://yugafarms.com
SUPPORT_PHONE=919671012177
